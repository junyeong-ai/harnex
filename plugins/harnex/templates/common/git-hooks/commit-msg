#!/usr/bin/env bash
# git commit-msg hook — validate commit message structure.
#
# Delegates to `harness validate commit-msg` when the binary is available;
# otherwise skips. The oracle validates closed-enum trailer values and
# required-trailer presence.
#
# Fail-open: missing harness binary → skip.
# Escape hatch via HARNEX_SKIP_COMMITMSG=1.
set -uo pipefail

[[ "${HARNEX_SKIP_COMMITMSG:-}" == "1" ]] && exit 0

command -v harness >/dev/null 2>&1 || exit 0

OUTPUT=$(harness validate commit-msg "$1" 2>&1)
STATUS=$?

case $STATUS in
  0) exit 0 ;;
  1) echo "[harnex] commit message validation failed:" >&2
     echo "$OUTPUT" >&2
     exit 1 ;;
  *) exit 0 ;;
esac
