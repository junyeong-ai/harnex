{
  "autoMemoryEnabled": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PROJECT_DIR}/hooks/_runner.sh", "args": ["post-format.sh"], "timeout": 15 }]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(harness *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git switch *)",
      "Bash(mkdir -p *)",
      "Edit",
      "Write"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(*credentials*.json)",
      "Read(/secrets/**)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/credentials)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.development)",
      "Write(.env.staging)",
      "Write(.env.production)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(*.p12)",
      "Write(*.pfx)",
      "Write(/secrets/**)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/credentials)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.development)",
      "Edit(.env.staging)",
      "Edit(.env.production)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Edit(*.p12)",
      "Edit(*.pfx)",
      "Edit(/secrets/**)",
      "Edit(~/.ssh/*)",
      "Edit(~/.aws/credentials)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git restore -- .)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(git rebase -i *)",
      "Bash(git add .)",
      "Bash(git add -A *)",
      "Bash(git add -u *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -rf .git*)",
      "Bash(chmod -R 777 *)",
      "Bash(sudo *)",
      "Bash(node -e *)",
      "Bash(node --eval *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(find * -exec *)",
      "Bash(find * -delete)"
    ]
  }
}
